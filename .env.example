# ─── Application ───────────────────────────────────────────────────
APP_NAME=ROOTGS
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Database ───────────────────────────────────────────────────────
POSTGRES_USER=rootgs
POSTGRES_PASSWORD=rootgs_secret
POSTGRES_DB=rootgs_db
DATABASE_URL=postgresql+asyncpg://rootgs:rootgs_secret@localhost:5432/rootgs_db

# ─── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AI APIs ────────────────────────────────────────────────────────
GOOGLE_GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-compatible-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Weather ────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=your-openweathermap-key-here
# Open-Meteo is free and requires no key (used as default)

# ─── Storage (AWS S3 Compatible) ────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_BUCKET_NAME=rootgs-media
AWS_REGION=ap-south-1
AWS_S3_ENDPOINT_URL=https://s3.amazonaws.com
# For local dev with MinIO: http://localhost:9000

# ─── CORS ───────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost

# ─── Email (SMTP) ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM=noreply@rootgs.ai

# ─── Firebase (Push Notifications) ──────────────────────────────────
FIREBASE_SERVER_KEY=your-firebase-server-key

# ─── Feature Flags ──────────────────────────────────────────────────
ENABLE_AI_FEATURES=true
ENABLE_VOICE_SUPPORT=true
AI_DEMO_MODE=true
